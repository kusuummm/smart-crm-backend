# Server
PORT=5000
NODE_ENV=development

# MongoDB (local)
MONGO_URI=mongodb://127.0.0.1:27017/smart-crm

# JWT
JWT_SECRET=82399773869251177886635004522495496464629588048342
JWT_EXPIRES_IN=7d

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:3000

# Nodemailer (Gmail SMTP)
# Use a Google "App Password", not your normal Gmail password.
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=youraddress@gmail.com
EMAIL_PASS=your_app_password
EMAIL_FROM="SmartCRM <youraddress@gmail.com>"

# Meta WhatsApp Cloud API-
WHATSAPP_TOKEN=your_meta_permanent_or_temp_access_token
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_BUSINESS_ACCOUNT_ID=your_waba_id
WHATSAPP_API_VERSION=v20.0
WHATSAPP_WEBHOOK_VERIFY_TOKEN=choose_any_random_string_and_reuse_it_in_meta_dashboard
